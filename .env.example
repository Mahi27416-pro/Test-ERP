PORT=5000

# MySQL connection
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=college_erp

# Set to true ONLY on first run to load college-erp.sql schema + seed data
# Change to false after first run to avoid re-seeding
RUN_SCHEMA=true

JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=7d
